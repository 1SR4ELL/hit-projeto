# ─── DATABASE (Railway fornece automaticamente) ────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── SEGURANÇA ─────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque-por-string-aleatoria-de-64-chars-minimo
# EXATAMENTE 32 caracteres:
ENCRYPTION_KEY=chave_de_32_caracteres_aes256!!

# ─── OPENAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── WHATSAPP BUSINESS API (Meta) ──────────────────────────────────────────────
META_APP_SECRET=seu_app_secret_do_meta
META_WEBHOOK_VERIFY_TOKEN=token_aleatorio_para_verificar_webhook

# ─── SERVIDOR ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://seu-frontend.vercel.app

# ─── UPLOAD ────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads
