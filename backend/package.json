    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "form-data": "^4.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.29.0",
    "pdf-parse": "^1.1.1",
    "pino": "^8.19.0",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1",
